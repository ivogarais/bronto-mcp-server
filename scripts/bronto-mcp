#!/usr/bin/env sh
set -eu

REPO_ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

if [ -f "$REPO_ROOT/.env" ]; then
  set -a
  # shellcheck disable=SC1091
  . "$REPO_ROOT/.env"
  set +a
fi

cd "$REPO_ROOT"
export BRONTO_MCP_TRANSPORT="${BRONTO_MCP_TRANSPORT:-stdio}"

if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
  exec "$REPO_ROOT/.venv/bin/python" -m bronto
fi

if command -v uv >/dev/null 2>&1; then
  exec uv run bronto-mcp
fi

echo "No $REPO_ROOT/.venv/bin/python found and uv is not available."
echo "Install dependencies first (./install.sh claude|codex|all)."
exit 1
